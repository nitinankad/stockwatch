      "versionNonce": 2097685403,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779667829422,
      "link": null,
      "locked": false,
      "text": "Reconciliation service\n- Fetches actual closing prices from\nAlpaca for every ticker that had a\nprediction that day\n- Updates the prediction_logs with\nactual_pct_change and error\n- Backfills actual_pct_change on the\nfeature_vectors table so those rows\nbecome valid training data.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "M3J9hr_MbmUDKQ5ZSFse4",
      "originalText": "Reconciliation service\n- Fetches actual closing prices from Alpaca for every ticker that had a prediction that day\n- Updates the prediction_logs with actual_pct_change and error\n- Backfills actual_pct_change on the feature_vectors table so those rows become valid training data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
