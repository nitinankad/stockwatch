      "seed": 1507706912,
      "version": 265,
      "versionNonce": 488394724,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779563285304,
      "link": null,
      "locked": false,
      "text": "Design an intelligent stock screener",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design an intelligent stock screener",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "E7Eyh3ZJYQnxT_Pyc4RLP",
      "type": "text",
      "x": 523,
      "y": 96.5,
      "width": 615.5,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aq",
      "roundness": null,
      "seed": 210545120,
      "version": 907,
      "versionNonce": 1790025339,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779668170621,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n- The screener must be able to retrieve news articles\nfrom RSS feeds to keep up to date with news\n- The screener must be able to predict the direction\nof a stock's price with confidence\n- The screener must maintain persisted historical data\nfor ideas and narratives\n- The screener must analyze and extract stock tickers\nfrom the news articles\n- The screener must be able to allow users to track stocks\nand share the lists with other people\n- The screener must be able to track stock prices and measure\nP&L for paper trading\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n- The screener must be able to retrieve news articles\nfrom RSS feeds to keep up to date with news\n- The screener must be able to predict the direction\nof a stock's price with confidence\n- The screener must maintain persisted historical data\nfor ideas and narratives\n- The screener must analyze and extract stock tickers\nfrom the news articles\n- The screener must be able to allow users to track stocks\nand share the lists with other people\n- The screener must be able to track stock prices and measure\nP&L for paper trading\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sMX2F_IhDF_FPmJh7EfRs",
      "type": "text",
      "x": 519,
      "y": 456.5,
      "width": 548.7333374023438,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 2095389728,
      "version": 231,
      "versionNonce": 1939575652,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779570074852,
      "link": null,
      "locked": false,
      "text": "Non-functional requirements:\n- Availability > Consistency\n- RSS feed must be retrieved every minute\n- No processing duplicate articles\n- Processing news articles can be done by local machines",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional requirements:\n- Availability > Consistency\n- RSS feed must be retrieved every minute\n- No processing duplicate articles\n- Processing news articles can be done by local machines",
      "autoResize": true,
      "lineHeight": 1.25
    },
