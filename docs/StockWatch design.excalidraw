    {
      "id": "wGfe1lyLgQRYfrrplnWZM",
      "type": "text",
      "x": 527,
      "y": 44.5,
      "width": 346.6499938964844,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
