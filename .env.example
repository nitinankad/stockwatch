# ── General ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=25

# ── Messaging ─────────────────────────────────────────────────────────────────
# Required by ingestion (to publish) and llm_analyzer (to consume).
# Default RabbitMQ install: amqp://guest:guest@localhost/
RABBITMQ_URL=amqp://guest:guest@localhost/

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://stockwatch:stockwatch@localhost:5432/stockwatch

# ── Blob storage ──────────────────────────────────────────────────────────────
# "local" writes blobs to LOCAL_BLOB_ROOT; "s3" writes to S3_BUCKET.
BLOB_BACKEND=local
LOCAL_BLOB_ROOT=./blob_store

# Required only when BLOB_BACKEND=s3
# Also used by training (model upload) and prediction (model download)
S3_BUCKET=stockwatch-news-dev
S3_REGION=us-east-1
# Uncomment for LocalStack
# S3_ENDPOINT_URL=http://localhost:4566

# S3 prefix for model files (default: models → s3://bucket/models/xgb_1h.json etc.)
# S3_PREFIX=models

# ── News ingestion (python -m ingestion news) ─────────────────────────────────
# Poll interval in seconds (default: 300)
NEWS_POLL_INTERVAL_SECONDS=300

# RSS feeds — optional, overrides the default list defined in config.py.
# Comma-separated URLs.
# RSS_FEEDS=https://finance.yahoo.com/news/rssindex,https://feeds.a.dj.com/rss/RSSMarketsMain.xml

# Alpaca Markets news
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Reddit — no credentials needed, uses the public JSON API
# Comma-separated subreddits (default: stocks,investing,wallstreetbets)
# REDDIT_SUBREDDITS=stocks,investing,wallstreetbets

# Finnhub — both must be set to enable
FINNHUB_API_KEY=
# Comma-separated tickers, e.g. AAPL,MSFT
FINNHUB_SYMBOLS=

# ── LLM Analyzer (python -m llm_analyzer) ────────────────────────────────────
# Requires DATABASE_URL and blob config above.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Queue name written by ingestion and consumed by llm_analyzer (default: raw_news)
# QUEUE_NAME=raw_news

# ── Feature engineering (python -m feature_eng) ──────────────────────────────
# Requires DATABASE_URL and RABBITMQ_URL above.
# Comma-separated prediction horizons (default: 1h,4h,1d)
# PREDICTION_HORIZONS=1h,4h,1d
# How many minutes of OHLCV bars to use for indicators (default: 120)
# OHLCV_LOOKBACK_MINUTES=120

# ── Prediction (python -m prediction) ────────────────────────────────────────
# Requires DATABASE_URL and RABBITMQ_URL above.
# Directory containing XGBoost model files named xgb_{horizon}.json
MODEL_DIR=./models
MODEL_VERSION=0.1.0

# ── Reconciliation — run nightly at 5 PM EST: python -m reconciliation ────────
# Requires ALPACA_API_KEY, ALPACA_API_SECRET, and DATABASE_URL above.

# ── Training — run weekly: python -m training ─────────────────────────────────
# Requires DATABASE_URL above. Writes model files to MODEL_DIR.
MIN_SAMPLES=100
TEST_SPLIT=0.2

# ── Backfill — run once: python -m backfill ───────────────────────────────────
# Requires ALPACA_API_KEY, ALPACA_API_SECRET, and DATABASE_URL above.
# Comma-separated tickers to backfill
BACKFILL_SYMBOLS=AAPL,MSFT,NVDA
# Date range (defaults: today - 180 days → today)
# BACKFILL_START=2024-01-01
# BACKFILL_END=2024-06-30
# How often to sample a feature vector from the bar stream (minutes)
SAMPLE_INTERVAL_MINUTES=15
# Prediction horizons — add longer ones for stronger signal (default: 1h,4h,1d)
# Available: 1h, 4h, 1d, 1w (5 trading days), 2w (10 trading days), 1m (~21 trading days)
# PREDICTION_HORIZONS=1h,4h,1d,1w,2w

# ── OHLCV polling (python -m ingestion ohlcv) ─────────────────────────────────
# Requires ALPACA_API_KEY, ALPACA_API_SECRET, and DATABASE_URL above.
# Poll interval in seconds (default: 60)
OHLCV_POLL_INTERVAL_SECONDS=60
# Comma-separated tickers to poll
OHLCV_SYMBOLS=NVDA

# ── Paper trader — in-memory, no brokerage account needed ─────────────────────
# Requires ALPACA_API_KEY and ALPACA_API_SECRET above (market data only).
# Run: python -m paper_trader          (loops every PAPER_POLL_INTERVAL_SECONDS)
#      python -m paper_trader --once   (single evaluation, good for testing)
# PAPER_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN
# PAPER_INITIAL_CASH=100000
# PAPER_POSITION_SIZE_USD=5000
# PAPER_TRADE_HORIZON=1h
# PAPER_MIN_SIGNAL_PCT=0.15
# PAPER_STOP_LOSS_PCT=1.5
# PAPER_TAKE_PROFIT_PCT=3.0
# PAPER_ALLOW_SHORTS=false
# PAPER_MAX_POSITIONS=5
# PAPER_OHLCV_TIMEFRAME=5Min
# PAPER_POLL_INTERVAL_SECONDS=300
# PAPER_ALPACA_FEED=iex       # 'iex' for free tier, 'sip' for paid Algo Trader Plus
