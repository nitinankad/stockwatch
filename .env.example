DATABASE_URL=postgresql://stockwatch:stockwatch@localhost:5432/stockwatch
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ANALYZE_ARTICLES=true
RETRY_FAILED_ARTICLES=false
PLAYWRIGHT_FALLBACK_ENABLED=true
HTTP_PROXY_URL=
# PROXY_URL is also supported as an alias.
REQUEST_TIMEOUT_SECONDS=25
LOG_LEVEL=INFO

# --- Finnhub WebSocket ---
FINNHUB_API_KEY=
# Comma-separated ticker symbols to subscribe to, or * for general news (requires premium plan).
# Example: AAPL,MSFT,META,GOOGL,AMZN,NVDA
FINNHUB_SYMBOLS=*

# --- Alpaca Markets WebSocket ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Comma-separated ticker symbols to subscribe to, or * for all news.
# Example: AAPL,MSFT,META,GOOGL,AMZN,NVDA
ALPACA_SYMBOLS=*
